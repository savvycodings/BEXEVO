ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GEMINI_API_KEY=""

# Public privacy policy contact (shown on /privacy and /privacy-policy)
# PRIVACY_CONTACT_EMAIL="knoome@proton.me"
# Optional; data deletion page defaults to PRIVACY_CONTACT_EMAIL if unset
# DATA_DELETION_CONTACT_EMAIL="knoome@proton.me"

# Better Auth (for onboarding / login)
BETTER_AUTH_SECRET=""
# Must match the exact origin users hit during OAuth (scheme + host + port, no trailing slash).
# - Simulator on same machine: http://localhost:3050 is OK.
# - Physical phone / Facebook / Safari: localhost is the device, not your PC — use your public HTTPS URL
#   (ngrok, Railway, etc.) and register that same URL in Meta: {BETTER_AUTH_URL}/api/auth/callback/facebook
# If Meta redirects to https://xxx.ngrok... but BETTER_AUTH_URL is localhost, cookies and post-login redirects break.
BETTER_AUTH_URL="http://localhost:3050"

# OAuth social sign-in (Better Auth). Each provider is registered only if BOTH ID and secret are set.
# If the app shows Google/Apple but these are missing, Better Auth returns oauth_provider_not_found.
# Redirect URIs: {BETTER_AUTH_URL}/api/auth/callback/google|facebook|apple
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""
# APPLE_APP_BUNDLE_IDENTIFIER="com.xevo.app"

# Meta Graph API webhooks (optional; separate from OAuth callback). Docs: https://developers.facebook.com/docs/graph-api/webhooks/getting-started
# You choose verify token; paste the same value in Meta dashboard "Verify Token" field.
META_WEBHOOK_VERIFY_TOKEN=""
# Optional alias; if unset, FACEBOOK_CLIENT_SECRET is used for X-Hub-Signature-256 validation.
# FACEBOOK_APP_SECRET=""
# Public base URL used for external services (e.g. Modal) to fetch server-hosted videos
# In local dev this can be your ngrok URL.
PUBLIC_VIDEO_BASE_URL=""
DATABASE_URL=""

# Optional: Cloudinary for technique video uploads
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
